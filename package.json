{
    "name": "swgohbot",
    "version": "3.0.0",
    "description": "Discord bot for the Star Wars Galaxy of Heroes game.",
    "main": "swgohBot.js",
    "type": "module",
    "scripts": {
        "start": "node swgohBotShard.ts",
        "lint": "biome check --no-errors-on-unmatched .",
        "lint:write": "biome check --write --no-errors-on-unmatched .",
        "deploy": "node ./modules/deployCommands.ts",
        "indexes": "node scripts/verifyIndexes.ts",
        "indexes:check": "node scripts/verifyIndexes.ts --dry-run",
        "indexes:create": "node scripts/verifyIndexes.ts --create",
        "test": "npm run test:modules && npm run test:slash && npm run test:cleanup",
        "test:modules": "node --test --import ./test/setup/mongodb.ts ./test/modules/*.test.ts",
        "test:slash": "node --test --import ./test/setup/mongodb.ts ./test/slash/*.test.ts",
        "test:cleanup": "rm -f /tmp/swgohbot-testcontainer.* && docker stop $(docker ps -q --filter 'ancestor=mongo:7.0') 2>/dev/null || true"
    },
    "author": "Jeffrey Milner",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/jmiln/SWGoHBot/issues"
    },
    "homepage": "https://github.com/jmiln/SWGoHBot#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jmiln/SWGoHBot.git"
    },
    "dependencies": {
        "@swgoh-utils/comlink": "^2.0.0",
        "async": "^3.2.6",
        "discord.js": "^14.25.1",
        "mongodb": "^7.0.0",
        "pino": "^10.3.0",
        "piscina": "^5.1.4",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "zod": "^4.3.6"
    },
    "engines": {
        "node": ">=25.2"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "@testcontainers/mongodb": "^11.11.0",
        "@types/async": "^3.2.25",
        "@types/node": "^25.0.3",
        "discord-api-types": "^0.38.38"
    },
    "overrides": {
        "undici": "^6.23"
    }
}
