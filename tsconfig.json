{
    "include": [
        "**/*.ts",
        "**/*.js"
    ],
    "exclude": [
        "**/node_modules",
        "**/*.test.ts"
    ],
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rewriteRelativeImportExtensions": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "verbatimModuleSyntax": true
    }
}
