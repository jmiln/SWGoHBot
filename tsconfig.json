{
    "include": ["**/*.ts", "**/*.js"],
    "exclude": ["**/node_modules", "**/wipCommands", "**/scripts", "**/*.test.ts"],
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "rewriteRelativeImportExtensions": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "strict": false,
        "target": "ESNext",
        "verbatimModuleSyntax": true
    }
}
