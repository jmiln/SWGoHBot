#!/bin/bash

# SWGoHBot Pre-Commit Hook
# Runs linting and tests before allowing commits
# Use 'git commit --no-verify' to bypass if absolutely necessary

echo "Running pre-commit checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

print_success() {
    printf "${GREEN}✓  %s${NC}\n" "$1"
}

print_error() {
    printf "${RED}✗  %s${NC}\n" "$1"
}

print_warning() {
    printf "${YELLOW}⚠  %s${NC}\n" "$1"
}

print_section() {
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "$1"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# Get list of staged TypeScript files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' || true)

if [ -z "$STAGED_TS_FILES" ]; then
    print_warning "No TypeScript files staged for commit"
    echo ""
    echo "Pre-commit checks skipped (no .ts files to check)"
    exit 0
fi

# 1. Biome check (lint + format)
print_section "Biome Check"
if npx @biomejs/biome check --no-errors-on-unmatched $STAGED_TS_FILES; then
    print_success "Biome check passed"
else
    print_error "Biome check failed"
    echo ""
    echo "Fix with: npm run lint:write"
    FAILED=1
fi

# 2. TypeScript Type Check
print_section "TypeScript Type Check"
if tsc --noEmit; then
    print_success "Type check passed"
else
    print_error "Type check failed"
    FAILED=1
fi

# 3. Run Tests (only if source files outside test/ are being committed)
if echo "$STAGED_TS_FILES" | grep -qv -E '^test/'; then
    print_section "Running Tests"
    echo "Running tests..."
    if npm test; then
        print_success "Tests passed"
    else
        print_error "Tests failed"
        FAILED=1
    fi
else
    print_warning "Only test files modified, skipping test run"
fi

# Final result
echo ""
print_section "Pre-Commit Summary"

if [ $FAILED -eq 0 ]; then
    print_success "All checks passed!"
    echo ""
    exit 0
else
    print_error "Some checks failed"
    echo ""
    echo "Fix the issues above or use 'git commit --no-verify' to bypass"
    echo "(only bypass if you're sure the changes are safe)"
    echo ""
    exit 1
fi
